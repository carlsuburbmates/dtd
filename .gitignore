# ────────────────────────────────────────────────────────────────────────────
# Bark&Bond — .gitignore
# ────────────────────────────────────────────────────────────────────────────

# Editors / IDE
.idea/
.vscode/
*.swp
.DS_Store

# ── Node / Yarn ────────────────────────────────────────────────────────────
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build outputs ──────────────────────────────────────────────────────────
/build
/dist
dist/
.next/
*.tsbuildinfo
/coverage

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
venv/
.venv/
.pytest_cache/
.ruff_cache/

# ── Caches ─────────────────────────────────────────────────────────────────
.cache/
.eslintcache

# ── Environment / secrets ──────────────────────────────────────────────────
# Real env files are never committed; the .env.example variants ARE.
.env
.env.*
*.env
credentials.json
*.pem
*.key
*token.json*
*credentials.json*
.credentials
!.env.example
!*.env.example
!**/.env.example

# ── Local-only memory / test creds ─────────────────────────────────────────
memory/test_credentials.md

# ── Build / export garbage ─────────────────────────────────────────────────
chunk_*
*.zip
*.tar
*.tar.gz
*.tgz
*.pack

# ── Misc ───────────────────────────────────────────────────────────────────
.chainlit
chainlit.md
.ipynb_checkpoints/
dump.rdb
.vercel
android-sdk/

.emergent/

# Codex local skill artifacts (machine-local; not part of app runtime)
.agents/
skills-lock.json
