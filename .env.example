# Root `.env` is for repo-level verification, operator tooling, and provider checks.
# It is not the authoritative app runtime source.

# Local verification targets
MONGO_URL=mongodb://localhost:27017
DB_NAME=dtd
ADMIN_PASS=change-me
REMOTE_BACKEND_URL=http://127.0.0.1:8001

# Provider verification / automation secrets used by repo-level scripts and checks
RENDER_API_KEY=
MONGODB_ATLAS_PUBLIC_KEY=
MONGODB_ATLAS_PRIVATE_KEY=
MONGODB_ATLAS_PROJECT_ID=
SENTRY_ACCESS_TOKEN=
RESEND_API_KEY=
RESEND_FROM=no-reply@dogtrainersdirectory.com.au
RESEND_REPLY_TO=info@dogtrainersdirectory.com.au
STRIPE_SECRET_KEY=
