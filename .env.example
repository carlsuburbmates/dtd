# Root `.env` is for local verification helpers and shared operator secrets.
# Real values stay local only; this file is placeholders/documentation.

# Shared local runtime defaults
MONGO_URL=mongodb://localhost:27017
DB_NAME=dtd
ADMIN_PASS=change-me
AUTONOMY_LOOP_OWNER=api
RUN_AUTONOMY_IN_API=1
PUBLIC_MATCHING_ENABLED=0
PUBLIC_LAUNCH_PHASE=supply_first
REMOTE_BACKEND_URL=http://127.0.0.1:8001

# Provider verification / automation secrets used by repo-level scripts
RENDER_API_KEY=
MONGODB_ATLAS_PUBLIC_KEY=
MONGODB_ATLAS_PRIVATE_KEY=
MONGODB_ATLAS_PROJECT_ID=
SENTRY_ACCESS_TOKEN=

# Optional shared outbound defaults
RESEND_API_KEY=
RESEND_FROM=no-reply@dogtrainersdirectory.com.au
RESEND_REPLY_TO=info@dogtrainersdirectory.com.au

# Optional future auth migration (disabled in current lock state)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
OPS_AUTH_MODE=passcode
OPS_ALLOWED_USER_IDS=
OPS_ALLOWED_ROLES=founder,admin,ops
OPS_ALLOW_LEGACY_PASSCODE=0
OPS_ALLOW_ANY_SIGNED_IN=0
